<?xml version="1.0" encoding="utf-8"?>

<!--
Specify basic information about the project, including how this project is build.
See https://castle-engine.io/project_manifest for documentation of this file.
-->

<project name="play_sounds"
  standalone_source="play_sounds_standalone.dpr"
  game_units="GameInitialize"
  qualified_name="io.castleengine.play.sounds"
>
  <compiler_options>
    <search_paths>
      <path value="code/" />
    </search_paths>
    <defines>
      <!--
        Define PLAY_SOUNDS_TEST_FMOD to use FMOD sound backend
        https://castle-engine.io/fmod .

        Note: To make it work, you still need FMOD library (dll, so...)
        and follow the rest of instructions at https://castle-engine.io/fmod .
        If you miss the FMOD library, the application will still work,
        but will use the default sound backend (OpenAL on most platforms,
        WebAudio on web) and you will see a message in log
        "FMOD library not available, aborting setting FMOD as sound backend".
      -->
      <!-- define>PLAY_SOUNDS_TEST_FMOD</define -->
    </defines>
  </compiler_options>
</project>
